# ┌─────────────────────────────────────────────────────────────┐
# │                     Java / JVM related                      │
# └─────────────────────────────────────────────────────────────┘
*.class
*.jar
*.war
*.ear
*.log

# ┌─────────────────────────────────────────────────────────────┐
# │                   Build directories                         │
# └─────────────────────────────────────────────────────────────┘
target/
build/
out/
*.gradle/
.gradle/

# ┌─────────────────────────────────────────────────────────────┐
# │                        IDE / Editor                         │
# └─────────────────────────────────────────────────────────────┘
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.sublime-*
*.swp
*.swo

# ┌─────────────────────────────────────────────────────────────┐
# │                   OS / Filesystem junk                      │
# └─────────────────────────────────────────────────────────────┘
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ┌─────────────────────────────────────────────────────────────┐
# │               Spring Boot / Configuration                   │
# └─────────────────────────────────────────────────────────────┘
# Local / sensitive configuration files – NEVER commit these!
application.properties
application.yml
application.yaml

# Profile-specific files (dev, test, prod, local, etc.)
application-*.properties
application-*.yml
application-*.yaml

# Externalized config / secrets
*.env
.env
.env.*
secrets/
config/local/
docker-compose.override.yml

# ┌─────────────────────────────────────────────────────────────┐
# │                      Logging & temp                         │
# └─────────────────────────────────────────────────────────────┘
logs/
*.log.*
log/
tmp/
temp/

# ┌─────────────────────────────────────────────────────────────┐
# │                 Maven / Gradle wrapper                      │
# └─────────────────────────────────────────────────────────────┘
.mvn/
mvnw
mvnw.cmd
gradlew
gradlew.bat
gradle-wrapper.jar
gradle-wrapper.properties

# ┌─────────────────────────────────────────────────────────────┐
# │                   Database / migrations                     │
# └─────────────────────────────────────────────────────────────┘
*.sql.bak
*.h2.db
*.mv.db
*.trace.db

